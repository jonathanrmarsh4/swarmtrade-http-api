# SwarmTrade HTTP API Server
# Copy this file to .env and customize for your environment

# Server
NODE_ENV=development
PORT=3000

# CORS
# Comma-separated list of allowed origins. Use * for development only.
CORS_ORIGINS=*

# MCP Server Configuration
# Endpoint where the SwarmTrade MCP server is running
MCP_ENDPOINT=http://localhost:3001

# Optional: Authentication token for MCP server (if required)
# MCP_AUTH_TOKEN=your-token-here

# Logging
# Log level: debug, info, warn, error
LOG_LEVEL=debug

# Rate Limiting
# Max requests per minute per IP
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100
